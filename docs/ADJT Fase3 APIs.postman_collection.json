          "}",
          "if (!pm.collectionVariables.get('user_email')) {",
          "    pm.collectionVariables.set('user_email', 'teste@example.com');",
          "}",
          "if (!pm.collectionVariables.get('user_password')) {",
          "    pm.collectionVariables.set('user_password', '123456');",
          "}"
        ]
